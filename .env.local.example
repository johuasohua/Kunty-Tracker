# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings → API in the Supabase dashboard).

# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used exclusively by the /api/quick-log route handler
# (iOS Shortcuts integration). Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
